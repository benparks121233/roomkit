# Copy this file to .env and fill in real values. Never commit .env.

# ── REQUIRED ─────────────────────────────────────────────────────────
# App will not function without these.

# LLM calls (style interpretation, composition, product selection)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Product sourcing via Canopy API
CANOPY_API_KEY=your-canopy-api-key

# ── FEATURE (graceful degradation if missing) ────────────────────────
# These enable specific features. The core design pipeline still works without them.

# Room render image generation (renders fail without this; designs still work)
OPENAI_API_KEY=your-openai-api-key

# Event tracking + admin analytics (tracking silently disabled if missing)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Publishable key (sb_publishable_...) for RLS-enforced reads.
# Found in Dashboard → Settings → API. Safe for client-side use with RLS enabled.
SUPABASE_ANON_KEY=your-publishable-key

# ⚠️  SUPABASE_SCHEMA — MUST match where your tables live (default: "public").
# All data (designs, user_packs, stripe_payments, events) lives in ONE schema.
# Railway staging uses "staging". If you omit this, the backend reads "public"
# and silently can't find packs/payments/designs in the staging schema.
# Symptom: paid packs aren't recognized → users hit free-tier limits.
SUPABASE_SCHEMA=staging

# JWT verification uses JWKS (ES256 asymmetric) — derived from SUPABASE_URL.
# No SUPABASE_JWT_SECRET needed for verification (legacy HS256 only).

# Admin dashboard auth — all /admin/* endpoints return 503 if unset
ADMIN_SECRET=your-admin-secret

# ── DEPLOY-REQUIRED (safe localhost defaults for dev, MUST set in production) ─
# These have localhost fallbacks that work in dev but silently break in prod.

# Public frontend URL — used for OG fallback image URLs. No trailing slash.
# If unset in production, OG images point at localhost:3000 (broken for crawlers).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Frontend→backend API URL (default: http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Redis for shared state (rate limiting, deleted-user blocklist, async render status).
# If unset, falls back to per-worker in-memory state (fine for single-worker / local dev).
REDIS_URL=redis://localhost:6379/0

# ── OPTIONAL (sensible defaults) ─────────────────────────────────────
# Only set these if you need to override the defaults.

# CORS allowed origins, comma-separated (default: http://localhost:3000,http://localhost:3001)
# CORS_ORIGINS=https://yourdomain.com

# Amazon affiliate tag injected into buy URLs (default: roomkitai-20)
# AMAZON_AFFILIATE_TAG=your-tag-20

# Render quality is tier-based (not configurable): free=medium (~$0.10), paid=high (~$0.30)

# Render image dimensions (default: 1536x1024)
# RENDER_SIZE=1536x1024

# Number of uvicorn workers (default: 1). Set to 2-4 for production.
# UVICORN_WORKERS=2

# Max concurrent LLM calls across all workers (default: 30).
# With Redis: global cap. Without Redis: divided evenly per worker.
# LLM_CONCURRENCY_CAP=30

# Max concurrent OpenAI render calls across all workers (default: 4).
# Cap=4 keeps throughput at ~6.9 IPM, under Tier 3's 7 IPM limit.
# RENDER_CONCURRENCY_CAP=4

# Set to "1" to disable event tracking in manual test runs (default: unset = tracking on)
# TESTING=1

# ── STRIPE (required for paid room packs) ────────────────────────────
# If missing, /checkout returns 503. Free tier works fine without these.

# Secret key from Dashboard → Developers → API keys (sk_test_* or sk_live_*)
STRIPE_SECRET_KEY=your-stripe-secret-key

# Webhook signing secret from Dashboard → Developers → Webhooks (whsec_*)
STRIPE_WEBHOOK_SECRET=your-webhook-signing-secret

# Default Price ID for checkout (price_*). Can also be passed per-request.
# STRIPE_PRICE_ID=price_xxx

# ── STAGING ──────────────────────────────────────────────────────────
# For Railway staging deployment (Phase 5D):
#   1. Create a Railway project linked to the roomkit GitHub repo.
#   2. Set all REQUIRED + DEPLOY-REQUIRED vars above in Railway Variables.
#   3. Set CORS_ORIGINS to the Railway-provided URL.
#   4. Supabase: uses the same project as dev/prod (shared DB is fine pre-launch).
#   5. Copy this file to .env.staging for local reference (git-ignored).
