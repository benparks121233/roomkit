# Copy this file to .env and fill in real values. Never commit .env.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (LLM for style, composition, selection)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Amazon Associates
AMAZON_AFFILIATE_TAG=your-affiliate-tag-20
AMAZON_ACCESS_KEY=your-access-key
AMAZON_SECRET_KEY=your-secret-key
AMAZON_ASSOCIATE_ID=your-associate-id

# Image generation (swappable render backend)
IMAGE_GEN_API_KEY=your-image-gen-key
IMAGE_GEN_PROVIDER=anthropic  # anthropic | openai | stability

# App
APP_ENV=development           # development | production
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# Railway (set automatically in Railway deploys)
PORT=8000
